<script>
  (() => {
    const sectionId = '{{ section.id }}';
    const sectionSelector = '.section-{{ section.id }}';
    const percentSelector = '.stats-card-percent-{{ section.id }}';
    const animationDuration = {{ section.settings.animation_duration | default: 5 }} * 1000;
    const globalHandlerKey = 'ssStats3Handlers';

    function cleanupStats(sectionElement) {
      if (!sectionElement) return;

      if (sectionElement._statsFrame) {
        cancelAnimationFrame(sectionElement._statsFrame);
        sectionElement._statsFrame = null;
      }

      if (sectionElement._statsObserver) {
        sectionElement._statsObserver.disconnect();
        sectionElement._statsObserver = null;
      }
    }

    function prepareSpans(spans) {
      spans.forEach((span) => {
        const target = Math.max(parseInt(span.dataset.target, 10) || 0, 0);
        span.style.display = 'inline-block';
        span.style.minWidth = 'calc(' + String(target).length + 'ch + 0.35ch)';
        span.textContent = '0';
      });
    }

    function animateSpans(sectionElement, spans) {
      const targets = Array.from(spans).map((span) => ({
        el: span,
        target: Math.max(parseInt(span.dataset.target, 10) || 0, 0),
      }));
      const maxTarget = Math.max(...targets.map((target) => target.target), 0);

      if (!maxTarget) {
        targets.forEach(({ el }) => {
          el.textContent = '0';
        });
        return;
      }

      const startTime = performance.now();

      const animateFrame = (currentTime) => {
        const progress = Math.min((currentTime - startTime) / animationDuration, 1);

        targets.forEach(({ el, target }) => {
          el.textContent = Math.round(target * progress);
        });

        if (progress < 1) {
          sectionElement._statsFrame = requestAnimationFrame(animateFrame);
        } else {
          sectionElement._statsFrame = null;
        }
      };

      sectionElement._statsFrame = requestAnimationFrame(animateFrame);
    }

    function initStats() {
      const sectionElement = document.querySelector(sectionSelector);
      if (!sectionElement) return;

      cleanupStats(sectionElement);

      const spans = sectionElement.querySelectorAll(percentSelector);
      if (!spans.length) return;

      prepareSpans(spans);

      if (typeof IntersectionObserver !== 'function') {
        animateSpans(sectionElement, spans);
        return;
      }

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;

          observer.disconnect();
          sectionElement._statsObserver = null;
          animateSpans(sectionElement, spans);
        });
      }, { threshold: 0.3 });

      observer.observe(sectionElement);
      sectionElement._statsObserver = observer;
    }

    function getEventSectionElement(event) {
      if (!event || !event.target) return document.querySelector(sectionSelector);

      if (event.target.matches && event.target.matches(sectionSelector)) {
        return event.target;
      }

      if (event.target.querySelector) {
        const nestedSection = event.target.querySelector(sectionSelector);
        if (nestedSection) return nestedSection;
      }

      return document.querySelector(sectionSelector);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initStats, { once: true });
    } else {
      initStats();
    }

    if (window.Shopify && Shopify.designMode) {
      window[globalHandlerKey] = window[globalHandlerKey] || {};

      const existingHandlers = window[globalHandlerKey][sectionId];
      if (existingHandlers) {
        document.removeEventListener('shopify:section:load', existingHandlers.load);
        document.removeEventListener('shopify:section:unload', existingHandlers.unload);
      }

      const handleSectionLoad = (event) => {
        if (!event.detail || event.detail.sectionId !== sectionId) return;
        initStats();
      };

      const handleSectionUnload = (event) => {
        if (!event.detail || event.detail.sectionId !== sectionId) return;

        cleanupStats(getEventSectionElement(event));
        document.removeEventListener('shopify:section:load', handleSectionLoad);
        document.removeEventListener('shopify:section:unload', handleSectionUnload);
        delete window[globalHandlerKey][sectionId];
      };

      document.addEventListener('shopify:section:load', handleSectionLoad);
      document.addEventListener('shopify:section:unload', handleSectionUnload);

      window[globalHandlerKey][sectionId] = {
        load: handleSectionLoad,
        unload: handleSectionUnload,
      };
    }
  })();
</script>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script>
  (() => {
    const sectionId = '{{ section.id }}';
    const sliderSelector = '.stats-slider-{{ section.id }}';
    const MOBILE_BP = 1024;
    let statsSwiper = null;

    function initStatsSwiper() {
      const sliderEl = document.querySelector(sliderSelector);
      if (!sliderEl) return;

      const isMobile = window.innerWidth < MOBILE_BP;

      if (isMobile && !statsSwiper) {
        statsSwiper = new Swiper(sliderEl, {
          slidesPerView: {{ cards_per_row_mobile }},
          spaceBetween: {{ cards_gap_mobile }},
          grabCursor: true,
          speed: 300,
        });
      } else if (!isMobile && statsSwiper) {
        statsSwiper.destroy(true, true);
        statsSwiper = null;
      }
    }

    function setupStatsSwiper() {
      if (typeof Swiper === 'undefined') return;
      initStatsSwiper();

      let resizeTimer;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(initStatsSwiper, 150);
      });

      if (window.Shopify && Shopify.designMode) {
        document.addEventListener('shopify:section:load', (e) => {
          if (e.detail.sectionId !== sectionId) return;
          if (statsSwiper) { statsSwiper.destroy(true, true); statsSwiper = null; }
          setTimeout(initStatsSwiper, 50);
        });
        document.addEventListener('shopify:section:unload', (e) => {
          if (e.detail.sectionId !== sectionId) return;
          if (statsSwiper) { statsSwiper.destroy(true, true); statsSwiper = null; }
        });
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', setupStatsSwiper, { once: true });
    } else {
      setupStatsSwiper();
    }
  })();
</script>

