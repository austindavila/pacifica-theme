<section>

   {% if page.handle == 'ingredients-glossary' %}
    <div class="row">

      <div class="col-xs-12" style="background-image:url({{ 'Glow-Baby-Ingredients-2.jpg' | file_url }}); width:100%; height: 500px; background-size:cover; background-repeat:no-repeat; background-position:50%; 50%;">
      </div>
   </div>
      <div class="page-content rte">
        {% render 'ingredients-glossary' %}
      </div>

    {% elsif page.handle == 'careers' %}
    <div class="row">
        <div class="col-xs-12" style="background-image:url({{ 'Careers-Header-GlowBaby.jpg' | file_url }}); width:100%; height: 300px; background-size:cover; background-repeat:no-repeat; background-position:50%; 50%;">
        </div>
     </div>

     <div class="container">   
      <div class="page-header__text-wrapper text-container">
          <h1 class="heading h2">{{ page.title }}</h1>
          <div class="page-content page-content--{{ section.settings.page_width }} rte" {% if page.handle == 'store-locator' %}style="max-width: 2000px; border: 1px solid lightgray;"{% endif %}>
            {{- page.content -}}
          </div>
      </div>
    </div>
  
    {% else %}
    
  <div class="container">    
    {% unless page.handle contains 'blog' or page.handle == 'pacifica-beauty-rewards-program' %}   

    <div class="page-header">
      <nav aria-label="{{ 'general.breadcrumb.title' | t }}" class="breadcrumb breadcrumb--floating text--xsmall hidden-phone">
        <ol class="breadcrumb__list" role="list">
          <li class="breadcrumb__item">
            <a class="breadcrumb__link" href="{{ routes.root_url }}">{{ 'general.breadcrumb.home' | t }}</a>
          </li>

          <li class="breadcrumb__item">
            <span class="breadcrumb__link" aria-current="page">{{ page.title }}</span>
          </li>
        </ol>
      </nav>

      <div class="page-header__text-wrapper text-container" {% if page.title == 'Search Results' %} style="display:none;"{% endif %}>
        {%- if section.settings.show_title -%}
          <h1 class="heading h2">{{ page.title }}</h1>
        {%- endif -%}

        {%- if template.suffix contains 'contact' or template.suffix contains 'faq' -%}
          {{- page.content -}}
        {%- endif -%}
      </div>
    </div>

{% endunless %}

    {%- unless template.suffix contains 'contact' or template.suffix contains 'faq' or page.handle contains 'blog' or page.handle contains 'rewards' -%}
      <div class="page-content page-content--{{ section.settings.page_width }} rte" {% if page.handle == 'store-locator' %}style="max-width: 2000px; border: 1px solid lightgray;"{% endif %}>
        {{- page.content -}}
      </div>
    {%- endunless -%}

    {% comment %} switching to template - this won't work anymore because we won't use this handle {% endcomment %}
     {% if page.handle == 'rewards' %}
        {% render 'loyalty-page' %}
    {% endif %} 
  

  </div>

  {% endif %}
  
</section>

{% schema %}
{
  "name": "Page",
  "class": "shopify-section--main-page",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show page title",
      "default": true
    },
    {
      "type": "select",
      "id": "page_width",
      "label": "Page width",
      "options": [
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "large",
          "label": "Large"
        }
      ],
      "default": "medium"
    }
  ]
}
{% endschema %}