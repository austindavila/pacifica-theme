{% if lazy %}
  <script src="https://cdn.jsdelivr.net/npm/vanilla-lazyload@19.1.3/dist/lazyload.min.js"></script>
{% endif %}

{% if lazy %}
  <script>
    (function () {
      var key = 'ssVB4Lazy_{{ section.id }}';

      function initVideoBanner() {
        if (window[key]) {
          window[key].update();
        } else {
          window[key] = new LazyLoad();
        }
      }

      document.addEventListener('DOMContentLoaded', initVideoBanner);

      if (Shopify.designMode) {
        document.addEventListener('shopify:section:unload', function (e) {
          if (e.detail.sectionId === '{{ section.id }}' && window[key]) {
            window[key].destroy();
            window[key] = null;
          }
        });
        document.addEventListener('shopify:section:load', function (e) {
          if (e.detail.sectionId === '{{ section.id }}') initVideoBanner();
        });
      }
    })();
  </script>
{% endif %}

{% if video_play_pause %}
  <script>
    (function () {
      var btn = document.querySelector('[data-vb-playpause="{{ section.id }}"]');
      if (!btn) return;

      var container = btn.closest('.section-{{ section.id }}-settings');
      var isPlaying = true;

      function updateIcons() {
        btn.querySelector('.vb-play-icon-{{ section.id }}').style.display = isPlaying ? 'none' : 'flex';
        btn.querySelector('.vb-pause-icon-{{ section.id }}').style.display = isPlaying ? 'flex' : 'none';
        btn.setAttribute('aria-label', isPlaying ? 'Pause video' : 'Play video');
      }

      btn.addEventListener('click', function () {
        isPlaying = !isPlaying;

        var videos = container.querySelectorAll('video');
        videos.forEach(function (v) {
          if (v.offsetParent !== null || getComputedStyle(v).display !== 'none') {
            isPlaying ? v.play() : v.pause();
          }
        });

        var iframe = container.querySelector('iframe');
        if (iframe) {
          var src = iframe.src || iframe.getAttribute('data-src') || '';
          if (src.indexOf('youtube') !== -1) {
            iframe.contentWindow.postMessage(
              JSON.stringify({ event: 'command', func: isPlaying ? 'playVideo' : 'pauseVideo' }),
              '*'
            );
          } else if (src.indexOf('vimeo') !== -1) {
            iframe.contentWindow.postMessage(JSON.stringify({ method: isPlaying ? 'play' : 'pause' }), '*');
          }
        }

        updateIcons();
      });
    })();
  </script>
{% endif %}

