{% endcomment %}

{%- liquid
  assign padding_horizontal = section.settings.padding_horizontal
  assign padding_horizontal_mobile = section.settings.padding_horizontal_mobile
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign section_border_alpha = section.settings.border_opacity | divided_by: 100.0
  assign border_color = section.settings.border_color | color_modify: 'alpha', section_border_alpha
  assign border_thickness = section.settings.border_thickness
  assign margin_top = section.settings.margin_top
  assign margin_bottom = section.settings.margin_bottom
  assign margin_horizontal_mobile = section.settings.margin_horizontal_mobile
  assign margin_horizontal = section.settings.margin_horizontal
  assign width = section.settings.width
  assign content_width = section.settings.content_width
  assign lazy = section.settings.lazy
  assign section_radius = section.settings.section_radius

  assign content_align = section.settings.content_align
  assign content_align_mobile = section.settings.content_align_mobile
  assign content_vertical_align = section.settings.content_vertical_align
  assign content_vertical_align_mobile = section.settings.content_vertical_align_mobile

  assign content_horizontal_align = ''
  if content_align == 'center'
    assign content_horizontal_align = 'center'
  elsif content_align == 'right'
    assign content_horizontal_align = 'end'
  else
    assign content_horizontal_align = 'start'
  endif

  assign content_horizontal_align_mobile = ''
  if content_align_mobile == 'center'
    assign content_horizontal_align_mobile = 'center'
  elsif content_align_mobile == 'right'
    assign content_horizontal_align_mobile = 'end'
  else
    assign content_horizontal_align_mobile = 'start'
  endif

  assign content_padding_vertical = section.settings.content_padding_vertical
  assign content_padding_vertical_mobile = section.settings.content_padding_vertical_mobile
  assign content_padding_horizontal = section.settings.content_padding_horizontal
  assign content_padding_horizontal_mobile = section.settings.content_padding_horizontal_mobile
  assign content_border_thickness = section.settings.content_border_thickness
  assign content_radius = section.settings.content_radius

  assign bg_alpha = section.settings.content_background_opacity | divided_by: 100.0
  assign border_alpha = section.settings.content_border_opacity | divided_by: 100.0
  assign bg_color = section.settings.content_background_color | color_modify: 'alpha', bg_alpha
  assign content_border = section.settings.content_border_color | color_modify: 'alpha', border_alpha

  assign layout_height = section.settings.layout_height
  assign layout_fixed_height = section.settings.layout_fixed_height
  assign layout_fixed_height_mobile = section.settings.layout_fixed_height_mobile

  assign video = section.settings.video
  assign video_url = section.settings.video_url
  assign source = section.settings.source
  assign video_loop = section.settings.video_loop
  assign video_play_pause = section.settings.video_play_pause
-%}

{%- style -%}
  .section-{{ section.id }} {
    margin-top: {{ margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ margin_bottom | times: 0.75 | round: 0 }}px;
    margin-left: {{ margin_horizontal_mobile }}rem;
    margin-right: {{ margin_horizontal_mobile }}rem;
  }

  .section-{{ section.id }}-settings {
    position: relative;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
    padding-top: {{ padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ padding_bottom | times: 0.75 | round: 0 }}px;
    padding-left: {{ padding_horizontal_mobile }}rem;
    padding-right: {{ padding_horizontal_mobile }}rem;
    border-top: solid {{ border_color }} {{ border_thickness }}px;
    border-bottom: solid {{ border_color }} {{ border_thickness }}px;
    border-radius: {{ section_radius | times: 0.6 | round: 0 }}px;
    overflow: hidden;
  }

  .video-banner-body-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr;
    flex-grow: 1;
    position: relative;
    z-index: 1;
  }

  .video-banner-video-{{ section.id }} {
    overflow: hidden;
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
  }

  .video-banner-video-{{ section.id }} video,
  .video-banner-video-{{ section.id }} iframe {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border: 0px;
  }

  .video-banner-content-{{ section.id }} {
    width: 100%;
    place-self: {{ content_vertical_align_mobile }} {{ content_horizontal_align_mobile }};
    backdrop-filter: blur(48px);
    border-radius: {{ content_radius }}px;
    padding: {{ content_padding_vertical_mobile }}px {{ content_padding_horizontal_mobile }}px;
    border: {{ content_border_thickness }}px solid {{ content_border }};
    background-color: {{ bg_color }};
  }

  .video-banner-stars-{{ section.id }} {
    display: flex;
    align-items: center;
    max-width: fit-content;
  }

  .video-banner-stars-wrapper-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: {{ content_align_mobile }};
    gap: 10px;
  }

  .video-banner-desktop-video-{{ section.id }} {
    display: none;
  }
  .video-banner-mobile-video-{{ section.id }} {
    display: block;
  }

  @media(min-width: 1024px) {

    .section-{{ section.id }} {
      margin-top: {{ margin_top }}px;
      margin-bottom: {{ margin_bottom }}px;
      margin-left: {{ margin_horizontal }}rem;
      margin-right: {{ margin_horizontal }}rem;
    }

    .section-{{ section.id }}-settings {
      padding: 0 5rem;
      padding-top: {{ padding_top }}px;
      padding-bottom: {{ padding_bottom }}px;
      padding-left: {{ padding_horizontal }}rem;
      padding-right: {{ padding_horizontal }}rem;
        border-radius: {{ section_radius }}px;
    }

    .video-banner-content-{{ section.id }} {
      width: 50%;
      place-self: {{ content_vertical_align }} {{ content_horizontal_align }};
      padding: {{ content_padding_vertical }}px {{ content_padding_horizontal }}px;
    }

    .video-banner-stars-wrapper-{{ section.id }} {
      justify-content: {{ content_align }};
    }

    .video-banner-desktop-video-{{ section.id }} {
      display: block;
    }
    .video-banner-mobile-video-{{ section.id }} {
      display: none;
    }

  }

  {% if video_play_pause %}
    .video-banner-playpause-{{ section.id }} {
      position: absolute;
      right: 20px;
      left: auto;
      {% if content_vertical_align_mobile == 'end' %}top: 20px; bottom: auto;{% else %}bottom: 20px; top: auto;{% endif %}
      z-index: 10;
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: rgba(0,0,0,0.45);
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      transition: background 0.2s;
    }
    .video-banner-playpause-{{ section.id }}:hover {
      background: rgba(0,0,0,0.65);
    }
    .video-banner-playpause-{{ section.id }} svg {
      display: block;
      width: 18px;
      height: 18px;
    }
    @media (min-width: 1024px) {
      .video-banner-playpause-{{ section.id }} {
        bottom: 20px;
        top: auto;
        {% if content_align == 'right' %}left: 20px; right: auto;{% else %}right: 20px; left: auto;{% endif %}
      }
    }
  {% endif %}
{%- endstyle -%}

{% if width == 'custom' %}
  <style>
    .section-{{ section.id }}-settings {
      max-width: {{ content_width }}px;
    }
  </style>
{% elsif width == 'page' %}
  <style>
    .section-{{ section.id }}-settings {
      max-width: clamp(100px, var(--page-content-width, var(--page-width)), 100%);
    }
  </style>
{% endif %}

{% if margin_horizontal_mobile > 0 or width != 'full' %}
  <style>
    .section-{{ section.id }}-settings {
      border-left: solid {{ border_color }} {{ border_thickness }}px;
      border-right: solid {{ border_color }} {{ border_thickness }}px;
    }

    @media(min-width: 1024px) {
      .section-{{ section.id }}-settings {
        border-left: 0px;
        border-right: 0px;
      }
    }
  </style>
{% endif %}

{% if margin_horizontal > 0 or width != 'full' %}
  <style>
    @media(min-width: 1024px) {
      .section-{{ section.id }}-settings {
        border-left: solid {{ border_color }} {{ border_thickness }}px;
        border-right: solid {{ border_color }} {{ border_thickness }}px;
      }
    }
  </style>
{% endif %}

{% if layout_height == 'full_screen' %}
  <style>
    .section-{{ section.id }}-settings {
      min-height: 100svh;
    }
  </style>
{% elsif layout_height == 'fixed_height' %}
  <style>
    .section-{{ section.id }}-settings {
      min-height: {{ layout_fixed_height_mobile }}px;
    }

    @media(min-width: 1024px) {
      .section-{{ section.id }}-settings {
        min-height: {{ layout_fixed_height }}px;
      }
    }
  </style>
{% endif %}

{% for block in section.blocks %}
  {% case block.type %}
    {% when 'review' %}
      <style>
        .video-banner-review-{{ block.id }} {
          width: 100%;
          margin-top: {{ block.settings.review_mt_mobile }}px;
        }

        .video-banner-stars-count-{{ block.id }} {
          word-wrap: break-word;
          margin: 0;
          font-size: {{ block.settings.review_size_mobile }}px;
          color: {{ block.settings.review_color }};
          line-height: {{ block.settings.review_height }}%;
          text-transform: unset;
          text-decoration: none;
          word-break: break-word;
        }

        .video-banner-stars-{{ block.id }} {
          gap: {{ block.settings.stars_gap }}px;
        }

        .video-banner-stars-{{ block.id }} svg,
        .video-banner-stars-{{ block.id }} img {
          display: block;
          width: {{ block.settings.stars_size_mobile }}px;
          height: {{ block.settings.stars_size_mobile }}px;
          object-fit: cover;
        }


        @media (min-width: 1024px) {
          .video-banner-review-{{ block.id }} {
            margin-top: {{ block.settings.review_mt }}px;
          }

          .video-banner-stars-count-{{ block.id }} {
            font-size: {{ block.settings.review_size }}px;
          }

          .video-banner-stars-{{ block.id }} svg,
          .video-banner-stars-{{ block.id }} img {
            width: {{ block.settings.stars_size }}px;
            height: {{ block.settings.stars_size }}px;
          }
        }
      </style>

      {% if block.settings.review_custom %}
        <style>
          {{ block.settings.review_font | font_face: font_display: 'swap' }}

          .video-banner-stars-count-{{ block.id }} {
            font-family: {{ block.settings.review_font.family }}, {{ block.settings.review_font.fallback_families }};
            font-weight: {{ block.settings.review_font.weight }};
            font-style: {{ block.settings.review_font.style }};
          }
        </style>
      {% endif %}
    {% when 'heading' %}
      <style>
        {% if block.settings.heading_accent_style == 'solid' %}
          .video-banner-heading-{{ block.id }} strong {
            color: {{ block.settings.heading_accent_color }};
            font-style: normal;
          }
        {% elsif block.settings.heading_accent_style == 'gradient' %}
          .video-banner-heading-{{ block.id }} strong {
            background: {{ block.settings.heading_accent_gradient }};
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            font-style: normal;
          }
        {% endif %}

        .video-banner-heading-{{ block.id }} {
          margin-top: {{ block.settings.heading_mt_mobile }}px;
          text-align: {{ content_horizontal_align_mobile }};
        }

        .video-banner-heading-{{ block.id }} * {
          margin: 0;
          font-size: {{ block.settings.heading_size_mobile }}px;
          color: {{ block.settings.heading_color }};
          line-height: {{ block.settings.heading_height }}%;
          text-transform: unset;
          text-decoration: none;
          word-break: break-word;
        }

        @media(min-width: 1024px) {

          .video-banner-heading-{{ block.id }} {
            margin-top: {{ block.settings.heading_mt }}px;
            text-align: {{ content_horizontal_align }};
          }

          .video-banner-heading-{{ block.id }} * {
            font-size: {{ block.settings.heading_size }}px;
          }
        }
      </style>

      {% if block.settings.heading_custom %}
        <style>
          {{ block.settings.heading_font | font_face: font_display: 'swap' }}

          .video-banner-heading-{{ block.id }} * {
            font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
            font-weight: {{ block.settings.heading_font.weight }};
            font-style: {{ block.settings.heading_font.style }};
          }
        </style>
      {% endif %}
    {% when 'text' %}
      <style>
        .video-banner-text-{{ block.id }} {
          margin-top: {{ block.settings.text_mt_mobile }}px;
          text-align: {{ content_horizontal_align_mobile }};
          position: relative;
          z-index: 2;
        }

        .video-banner-text-{{ block.id }} * {
          margin: 0;
          font-size: {{ block.settings.text_size_mobile }}px;
          color: {{ block.settings.text_color }};
          line-height: {{ block.settings.text_height }}%;
          text-transform: unset;
          text-decoration: none;
          word-break: break-word;
        }

        @media(min-width: 1024px) {

          .video-banner-text-{{ block.id }} {
            margin-top: {{ block.settings.text_mt }}px;
            text-align: {{  content_horizontal_align }};
          }

          .video-banner-text-{{ block.id }} * {
            font-size: {{ block.settings.text_size }}px;
          }

        }
      </style>

      {% if block.settings.text_custom %}
        <style>
          {{ block.settings.text_font | font_face: font_display: 'swap' }}

          .video-banner-text-{{ block.id }} * {
            font-family: {{ block.settings.text_font.family }}, {{ block.settings.text_font.fallback_families }};
            font-weight: {{ block.settings.text_font.weight }};
            font-style: {{ block.settings.text_font.style }};
          }
        </style>
      {% endif %}
    {% when 'button' %}
      <style>
        .video-banner-button-{{ block.id }} {
          display: flex;
          align-items: center;
          justify-content: center;
          gap: 10px;
          width: 100%;
          margin: 0;
          font-size: {{ block.settings.button_size_mobile }}px;
          color: {{ block.settings.button_color }};
          line-height: {{ block.settings.button_height }}%;
          text-align: center;
          text-transform: unset;
          text-decoration: none;
          word-break: break-word;
          padding: {{ block.settings.button_padding_vertical_mobile }}px {{ block.settings.button_padding_horizontal_mobile }}px;
          border-radius: {{ block.settings.button_radius }}px;
          transition: all 0.3s ease 0s;
          background-color: transparent;
          border: 0px;
          margin-top: {{ block.settings.button_mt_mobile }}px;
          cursor: pointer;
          {% if block.settings.button_shadow %}
            box-shadow: 0px 10px 15px -3px #0000000D, 0px 4px 8px 4px #0000000D;
          {% endif %}
        }

        .video-banner-button-inner-{{ block.id }} {
          margin: 0px;
          display: flex;
          align-items: center;
          justify-content: center;
          gap: 10px;
          text-decoration: none;
        }

        .video-banner-button-{{ block.id }}:hover {
          color: {{ block.settings.button_hover_color }};
          transition: all 0.25s ease 0s;
        }

        .video-banner-button-{{ block.id }} svg {
            width: 14px !important;
          height: 14px !important;
          background: transparent;
          min-height: auto !important;
        }

        .video-banner-button-{{ block.id }} svg path {
          fill: {{ block.settings.button_color }};
          transition: all 0.25s ease 0s;
        }

        .video-banner-button-{{ block.id }}:hover svg path {
          fill: {{ block.settings.button_hover_color }};
          transition: all 0.25s ease 0s;
        }

        @media (min-width: 1024px) {
          .video-banner-button-{{ block.id }} {
            margin-top: {{ block.settings.button_mt }}px;
            padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
            font-size: {{ block.settings.button_size }}px;
          }
        }
      </style>

      {% if block.settings.button_custom %}
        <style>
          {{ block.settings.button_font | font_face: font_display: 'swap' }}

          .video-banner-button-{{ block.id }} {
            font-family: {{ block.settings.button_font.family }}, {{ block.settings.button_font.fallback_families }};
            font-weight: {{ block.settings.button_font.weight }};
            font-style: {{ block.settings.button_font.style }};
          }
        </style>
      {% endif %}

      {% if block.settings.button_style == 'non_outline' or block.settings.button_style == 'non_outline_arrow' %}
        <style>
          .video-banner-button-{{ block.id }} {
            transition: all 0.3s ease 0s;
            background-color: {{  block.settings.button_bg_color }};
          }

          .video-banner-button-{{ block.id }}:hover {
            transition: all 0.3s ease 0s;
            background-color: {{  block.settings.button_bg_hover_color }};
          }
        </style>
      {% elsif block.settings.button_style == 'outline' or block.settings.button_style == 'outline_arrow' %}
        <style>
          .video-banner-button-{{ block.id }} {
            transition: all 0.3s ease 0s;
            background-color: {{  block.settings.button_bg_color }};
            border: {{  block.settings.button_border_thickness }}px solid {{  block.settings.button_border_color }};
          }

          .video-banner-button-{{ block.id }}:hover {
            transition: all 0.3s ease 0s;
            background-color: {{  block.settings.button_bg_hover_color }};
            border: {{  block.settings.button_border_thickness }}px solid {{ block.settings.button_border_hover_color }};
          }
        </style>
      {% elsif block.settings.button_style == 'link' %}
        <style>
          .video-banner-button-{{ block.id }} {
            padding: 0px !important;
            -webkit-box-shadow: none !important;
            -moz-box-shadow: none !important;
            box-shadow: none !important;
          }
        </style>
      {% endif %}
  {% endcase %}
{% endfor %}

<div class="section-{{ section.id }} video-banner-{{ section.id }}">
  <div class="section-{{ section.id }}-settings">
    <div class="video-banner-video-{{ section.id }}">
      {% assign video_url_id = video_url.id %}
      {% assign loop_url = '&loop=1&playlist=' | append: video_url_id %}
      {%- if source != 'uploaded' -%}
        {% if video_url != blank %}
          {% if video_url.type == 'youtube' -%}
            <iframe
              {% if lazy %}
                data-
              {% endif -%}
              src="https://www.youtube.com/embed/{{ video_url_id }}?enablejsapi=1&mute=1&autoplay=1&controls=0&loop={% if video_loop %}1{% else %}0{% endif %}&modestbranding=1&showinfo=0&rel=0{{ loop_url }}"
              allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture"
              {% if lazy %}
                class="lazy"
              {% endif %}
            ></iframe>
          {% else %}
            <iframe
              {% if lazy %}
                data-
              {% endif -%}
              src="https://player.vimeo.com/video/{{ video_url_id }}?enablejsapi=1&mute=1&muted=1&autoplay=1&controls=0&loop={% if video_loop %}1{% else %}0{% endif %}&modestbranding=1&showinfo=0&rel=0{{ loop_url }}"
              allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture"
              {% if lazy %}
                class="lazy"
              {% endif %}
            ></iframe>
          {% endif %}
        {% else %}
          {% assign placeholder_video = 'https://cdn.shopify.com/videos/c/o/v/fbb140fd46e3429eba459e1549dbbe38.mp4' %}
          <video
            {% if lazy %}
              data-
            {% endif -%}
            src="{{ placeholder_video }}"
            muted
            autoplay
            playsinline
            preload="none"
            {% if video_loop %}
              loop
            {% endif -%}
            {% if lazy %}
              class="lazy"
            {% endif %}
          ></video>
        {% endif %}
      {% else %}
        {% assign placeholder_video = 'https://cdn.shopify.com/videos/c/o/v/fbb140fd46e3429eba459e1549dbbe38.mp4' %}
        {%- assign mobile_video = section.settings.video_mobile -%}
        <video
          {% if lazy %}
            data-
          {% endif -%}
          src="{% if video != blank %}{{ video.sources[1].url }}{% else %}{{ placeholder_video }}{% endif %}"
          muted
          autoplay
          playsinline
          preload="none"
          {% if video_loop %}
            loop
          {% endif %}
          class="{% if lazy %}lazy {% endif %}{% if mobile_video != blank %}video-banner-desktop-video-{{ section.id }}{% endif %}"
        ></video>
        {% if mobile_video != blank %}
          {%- assign mobile_video_src = mobile_video.sources[1].url | default: mobile_video.sources[0].url -%}
          <video
            {% if lazy %}
              data-
            {% endif -%}
            src="{{ mobile_video_src }}"
            muted
            autoplay
            playsinline
            preload="none"
            {% if video_loop %}
              loop
            {% endif %}
            class="{% if lazy %}lazy {% endif %}video-banner-mobile-video-{{ section.id }}"
          ></video>
        {% endif %}
      {% endif %}
    </div>
    <div class="video-banner-body-{{ section.id }}">
      <div class="video-banner-content-{{ section.id }}">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'review' %}
              {%- assign star_img_w = block.settings.stars_size | default: 14 -%}
              {%- if block.settings.stars_size_mobile > star_img_w -%}
                {%- assign star_img_w = block.settings.stars_size_mobile -%}
              {%- endif -%}
              {%- assign star_img_w = star_img_w | times: 3 -%}
              {% if block.settings.stars_text != blank or block.settings.stars_count != 0 %}
                <div class="video-banner-review-{{ block.id }}">
                  {% if block.settings.review_link != blank %}
                    <a
                      href="{{ block.settings.review_link }}"
                      class="video-banner-stars-wrapper-{{ section.id }}"
                      style="text-decoration: none;"
                    >
                  {% else %}
                    <div class="video-banner-stars-wrapper-{{ section.id }}">
                  {% endif %}
                  {% if block.settings.stars_count != 0 %}
                    <div class="video-banner-stars-{{ section.id }} video-banner-stars-{{ block.id }}">
                      {% if block.settings.stars_icon != blank %}
                        {%- assign sc = block.settings.stars_count -%}
                        {%- assign sc_floor = sc | floor -%}
                        {%- assign sc_ceil = sc | ceil -%}
                        {%- assign sc_has_half = false -%}
                        {%- if sc != sc_floor -%}{%- assign sc_has_half = true -%}{%- endif -%}
                        {% for i in (1..5) %}
                          {%- if i <= sc_floor -%}
                            <img
                              src="{{ block.settings.stars_icon | image_url: width: star_img_w }}"
                              alt="{{ block.settings.stars_icon.alt }}"
                              width="{{ block.settings.stars_size }}"
                              height="{{ block.settings.stars_size }}"
                            >
                          {%- elsif sc_has_half and i == sc_ceil -%}
                            {%- if block.settings.stars_icon_half != blank -%}
                              <img
                                src="{{ block.settings.stars_icon_half | image_url: width: star_img_w }}"
                                alt="{{ block.settings.stars_icon_half.alt }}"
                                width="{{ block.settings.stars_size }}"
                                height="{{ block.settings.stars_size }}"
                              >
                            {%- else -%}
                              <img
                                src="{{ block.settings.stars_icon | image_url: width: star_img_w }}"
                                alt="{{ block.settings.stars_icon.alt }}"
                                width="{{ block.settings.stars_size }}"
                                height="{{ block.settings.stars_size }}"
                              >
                            {%- endif -%}
