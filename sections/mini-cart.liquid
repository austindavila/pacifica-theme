      "options": [
        {
          "value": "shopping_bag",
          "label": "Shopping bag"
        },
        {
          "value": "shopping_cart",
          "label": "Shopping cart"
        },
        {
          "value": "tote_bag",
          "label": "Tote bag"
        }
