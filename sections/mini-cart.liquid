    },
    {
      "type": "checkbox",
      "id": "show_custom_cart_message",
      "label": "Show custom cart message",
      "default": true
    },
    {
      "type": "html",
      "id": "custom_cart_message",
      "label": "Custom messaging to appear at the top of the mini-cart"
    },
    {
      "type": "header",
      "content": "Cross-sell",
      "info": "Dynamic recommendations are based on the items in your cart. They change and improve with time. [Learn more](https://help.shopify.com/en/themes/development/recommended-products)"
