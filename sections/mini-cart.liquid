    },
    {
      "type": "text",
      "id": "free_gift_title",
      "label": "Free Gift heading",
      "default": "Choose Your Free Gift"
    },
    {
      "type": "product",
      "id": "free_gift_product_one",
      "label": "Free Gift Product"
    },
    {
      "type": "product",
      "id": "free_gift_product_two",
      "label": "Free Gift Product"
    },
    {
      "type": "product",
      "id": "free_gift_product_three",
      "label": "Free Gift Product",
      "info": "DISABLED"
    },
    {
      "type": "product",
      "id": "free_gift_product_four",
      "label": "Free Gift Product",
      "info": "DISABLED"
    }
  ]
}
{% endschema %}