        "html": "<div class=\"table-outer-container\">\n    <div class=\"table-inner-container\">\n        <div class=\"table-scroll-container\">\n            <table class=\"comparison-table\">\n                <tbody>\n                    <tr>\n                        <th class=\"no-padding\"></th>\n                        <th class=\"no-padding table-cell-darker\">Surf Lash</th>\n                        <th class=\"no-padding table-cell-lightest\">Dream Big</th>\n                        <th class=\"no-padding\"><a href=\"https://www.pacificabeauty.com/collections/eye-conic-lashes/products/vegan-collagen-fluffy-lash-mascara\"><img src=\"https://cdn.shopify.com/s/files/1/1515/0462/files/Mascara-Infographic-Fluffy.jpg?v=1691154457\" alt=\"Vegan Collagen Fluffy Lash Mascara\" class=\"table-img\"></a></th>\n                        <th class=\"no-padding\"><a href=\"https://www.pacificabeauty.com/collections/eye-conic-lashes/products/stellar-gaze-length-strength-mineral-mascara\"><img src=\"https://cdn.shopify.com/s/files/1/1515/0462/files/Mascara-Infographic-Stellar.jpg?v=1691154457\" alt=\"Stellar Gaze Mascara\" class=\"table-img\"></a></th>\n                        <th class=\"no-padding\"><a href=\"https://www.pacificabeauty.com/collections/eye-conic-lashes/products/activist-volume-mascara\"><img src=\"https://cdn.shopify.com/s/files/1/1515/0462/files/Mascara-Infographic-Activist.jpg?v=1691154457\" alt=\"Activist Volume &amp; Curl Mascara\" class=\"table-img\"></a></th>\n                    </tr>\n                    <tr>\n                        <td class=\"table-cell-lightest\"><span class=\"heading heading--small text--center\">Features</span></td>\n                        <td class=\"table-cell-carker\">\n                            <ul>\n                                <li><span class=\"heading heading--small\">surf lash</span></li>\n                            </ul>\n                        </td>\n                        <td class=\"table-cell-lightest\">\n                            <ul>\n                                <li><span class=\"heading heading--small\">dream big</span></li>\n                            </ul>\n                        </td>\n                        <td class=\"table-cell-darker\">\n                            <ul>\n                                <li><span class=\"heading heading--small\">Get natural and fluffy lashes</span></li>\n                            </ul>\n                        </td>\n                        <td class=\"table-cell-lightest\">\n                            <ul>\n                                <li><span class=\"heading heading--small\">Get long and strong lashes</span></li>\n                            </ul>\n                        </td>\n                        <td class=\"table-cell-darker\">\n                            <ul>\n                                <li><span class=\"heading heading--small\">Get volumized and curled lashes</span></li>\n                            </ul>\n                        </td>\n                    </tr>\n                    <tr>\n                        <td class=\"table-cell-lightest\"><span class=\"heading heading--small text--center\">Brush</span></td>\n                        <td class=\"table-cell-darker\">\n                            <ul>\n                                <li>Lorem ipsum dolor sit amet</li>\n                                <li>Consectetur adipiscing elit</li>\n                                <li>Sed do eiusmod tempor incididunt</li>\n                            </ul>\n                        </td>\n                        <td class=\"table-cell-lightest\">\n                            <ul>\n                                <li>Lorem ipsum dolor sit amet</li>\n                                <li>Consectetur adipiscing elit</li>\n                                <li>Sed do eiusmod tempor incididunt</li>\n                            </ul>\n                        </td>\n                        <td class=\"table-cell-darker\">\n                            <ul>\n                                <li>100% vegan spiral fluff it up brush to fluff &amp; fan out every lash</li>\n                                <li>Lifts for fluffy lashes that look beyond natural</li>\n                                <li>Flexible bristles designed to spread evenly onto every single lash to fluff and for a feathery, fluttery effect</li>\n                            </ul>\n                        </td>\n                        <td class=\"table-cell-lightest\">\n                            <ul>\n                                <li>100% vegan soft brush</li>\n                                <li>Natural looking length and volume </li>\n                                <li>Plush bristles designed for effortless, buildable, coverage</li>\n                            </ul>\n                        </td>\n                        <td class=\"table-cell-darker\">\n                            <ul>\n                                <li>100% vegan custom curved brush</li>\n                                <li>Contours lashes to lift, add volume and curl from root to tip</li>\n                                <li>Flexible bristles designed to load up lashes for maximum volume</li>\n                            </ul>\n                        </td>\n                    </tr>\n                    <tr>\n                        <td class=\"table-cell-lightest\"><span class=\"heading heading--small text--center\">Ingredients</span></td>\n                        <td class=\"table-cell-darkert\">\n                            <ul>\n                                <li>Lorem ipsum dolor sit amet</li>\n                                <li>Consectetur adipiscing elit</li>\n                                <li>Sed do eiusmod tempor incididunt</li>\n                            </ul>\n                        </td>\n                        <td class=\"table-cell-lightest\">\n                            <ul>\n                                <li>Lorem ipsum dolor sit amet</li>\n                                <li>Consectetur adipiscing elit</li>\n                                <li>Sed do eiusmod tempor incididunt</li>\n                            </ul>\n                        </td>\n                        <td class=\"table-cell-darker\">\n                            <ul>                        \n                                <li>\n<span class=\"table-semibold\">Vegan Collagen:</span> Add structure and build volume</li>\n                                <li>\n<span class=\"table-semibold\">Plant Fibers:</span> Conditions and helps hydrate</li>\n                            </ul>\n                        </td>\n                        <td class=\"table-cell-lightest\">\n                            <ul>\n                                <li>\n<span class=\"table-semibold\">Vitamin B:</span> Nourishes lashes from root to tip</li>\n                                <li>\n<span class=\"table-semibold\">Coconut Oil:</span> Helps to hydrate for a fuller, healthier appearance </li>\n                                <li>\n<span class=\"table-semibold\">Kelp:</span> Rich in nutrients to support healthy lashes </li>\n                            </ul>\n                        </td>\n                        <td class=\"table-cell-darker\">\n                            <ul>\n                                <li>\n<span class=\"table-semibold\">Plant Waxes:</span> Add structure and build volume</li>\n                                <li>\n<span class=\"table-semibold\">Plant Fibers:</span> Amplify volume and adds length</li>\n                                <li>\n<span class=\"table-semibold\">Shorea Robusta Resin &amp; Acacia Senegal Gum:</span> Film forming &amp; curl</li>\n                                <li>\n<span class=\"table-semibold\">Plant Oils &amp; Vegan Collagen:</span> Nourish and condition</li>\n                            </ul>\n                        </td>\n                    </tr>\n                    <tr>\n                        <td class=\"table-cell-lightest\"><span class=\"heading heading--small text--center\">Packaging</span></td>\n                        <td class=\"table-cell-darker\">\n                            <ul>\n                                <li>Lorem ipsum dolor sit amet</li>\n                                <li>Consectetur adipiscing elit</li>\n                                <li>Sed do eiusmod tempor incididunt</li>\n                            </ul>\n                        </td>\n                        <td class=\"table-cell-lightest\">\n                            <ul>\n                                <li>Lorem ipsum dolor sit amet</li>\n                                <li>Consectetur adipiscing elit</li>\n                                <li>Sed do eiusmod tempor incididunt</li>\n                            </ul>\n                        </td>\n                        <td class=\"table-cell-darker\">\n                            <ul>\n                                <li>96% naturally derived ingredients</li>\n                                <li>100% glass bottle</li>\n                                <li>Zero Microplastics</li>\n                            </ul>\n                        </td>\n                        <td class=\"table-cell-lightest\">\n                            <ul>\n                                <li>96% naturally derived ingredients</li>\n                                <li>FSC carton</li>\n                                <li>Zero Microplastics</li>\n                            </ul>\n                        </td>\n                        <td class=\"table-cell-darker\">\n                            <ul>\n                                <li>96% naturally derived ingredients</li>\n                                <li>100% glass bottle</li>\n                                <li>Zero Microplastics</li>\n                            </ul>\n                        </td>\n                    </tr>\n                </tbody>\n            </table>\n        </div>\n    </div>\n</div>\n\n\n<style>\n    /* General styles for all tables (outside the scope) */\n    table {\n        border-collapse: collapse;\n        width: 100%;\n    }\n    th, td {\n        border: 1px solid #ccc; /* Add gray border to all cells */\n        text-align: left;\n        min-width: 200px; /* Set the minimum width for all columns */\n    }\n\n    td{\n        padding-left:10px;\n    }\n    th.no-padding {\n        padding: 0 !important; /* Remove padding from table header cells with images */\n    }\n    img {\n        display: block; /* Remove extra space around the images */\n        width: 100%; /* Images fill the width of the container they are in */\n        height: auto;\n    }\n\n    /* Styles specific to the comparison table with the class \"comparison-table\" */\n    .comparison-table ul{\n        /* Add your specific styles here */\n        list-style: none;\n    }\n    .comparison-table li{\n        padding: 5px 0;\n        line-height: normal;\n    }\n    \n    /* Styles specific to <img> elements within the table with class \"table-img\" */\n    .comparison-table .table-img {\n        /* Add any other specific image styles here */\n    }\n\n    /* Styles for the outer container */\n    .table-outer-container {\n        overflow-x: auto;\n    }\n\n    /* Styles for the inner container */\n    .table-inner-container {\n        width: 100%;\n        /* Add padding or margin here if needed */\n    }\n\n    /* Styles for the scroll container */\n    .table-scroll-container {\n        min-width: 100%; /* Ensures horizontal scroll behavior */\n        overflow-x: auto;\n    }\n\n    /* Background styles for table cells */\n    .table-cell-lightest {\n        background-color: #fff0f4; /* Lightest pink background for table cells */\n    }\n\n    .table-cell-darker {\n        background-color:  #fffafb;/* Darker pink background for table cells */\n    }\n\n    /* Remove padding for all cells */\n    .comparison-table th,\n    .comparison-table td {\n        padding: 10px;\n    }\n    .comparison-table ul {\n        padding-left:5px;\n    }\n\n    .comparison-table .table-semibold{\n        font-weight:500;\n    }\n    /* Responsive styles for mobile devices */\n    @media (max-width: 600px) {\n        .comparison-table th, .comparison-table td {\n            /* font-size: 12px; */\n            width: 200px; /* Set a specific width for columns on mobile */\n        }\n        .comparison-table th:first-child,\n        .comparison-table td:first-child {\n            min-width: 70px; /* Adjust the width as needed */\n        }\n    }\n</style>",
