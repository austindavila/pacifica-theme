    "custom_html_3npjgA": {
      "type": "custom-html",
      "disabled": true,
      "custom_css": [
        ".section__color-wrapper {padding: 40px 0; background: rgb(255, 211, 171); background: radial-gradient( circle, rgba(255, 211, 171, 1) 0%, rgba(255, 208, 198, 1) 68%, rgba(255, 208, 233, 1) 100% );}",
        "p {width: 90%; padding-top: 10px; margin: auto; line-height: normal;}"
      ],
      "settings": {
        "subheading": "",
        "title": "",
        "html": "<div class=\"row center-xs\">\n\n<div class=\" col-xs-12 col-md-10 text--center\" style=\"padding-bottom:35px;\"> <span class=\"header heading--large font-california-coast\">reasons to love <br class=\"hidden-lap-and-up\">glow baby</span>\n</div>\n\n<div class=\"col-xs-12 col-md-4 col-lg-4\">\n<div style=\"padding-bottom:15px;\"><img src=\"https://cdn.shopify.com/s/files/1/1515/0462/files/glow-baby-landing-why2.png?v=1717035047\" style=\"width:70%\"></div>\n<span class=\"h5\">Radiant skin</span>\n<p>Packed with antioxidant-rich Vitamin C, Glow Baby products brighten and even skin tone for a softer, smoother, more radiant complexion. </p>\n</div>\n\n<div class=\"col-xs-12 col-md-4 col-lg-4\">\n<div style=\"padding-bottom:15px;\"><img src=\"https://cdn.shopify.com/s/files/1/1515/0462/files/glow-baby-landing-why1b.png?v=1717081227\" style=\"width:70%;\"></div>\n<span class=\"h5\">Next-generation formulas <br>(ingredients that work!) </span>\n<p>We're experts in creating skin-first formulas made with future forward ingredients backed by science for positively transformative, radiant results. </p>\n</div>\n\n\n<div class=\"col-xs-12 col-md-4 col-lg-4\">\n<div style=\"padding-bottom:15px;\"><img src=\"https://cdn.shopify.com/s/files/1/1515/0462/files/glow-baby-landing-why3.png?v=1717035047\" style=\"width:70%;\"></div>\n<span class=\"h5\">Conscious Beauty <br>(beauty with a higher purpose) </span>\n<p>We uphold our Compassionism<sup>TM</sup> standards with 100% vegan, cruelty-free products using skintentional formulas safe for the planet, animals, and you, leaving out over 1,800 harmful ingredients. </p>\n</div>\n\n\n</div>",
        "no_padding_margin": false,
        "background_type": "full_width",
        "background": "rgba(0,0,0,0)",
        "text_color": "rgba(0,0,0,0)"
      }
    },
