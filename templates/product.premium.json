        "title": "",
        "liquid": "{% if product.tags contains \"suncare\" %}\n{% assign product = all_products['after-sun-cool-glow-chest-area-sheet-mask'] %}\n<div class=\"row center-xs middle-xs\">\n\n    <div class=\"text--center col-xs-12 col-md-4\" style=\"margin:0;\">\n        <img src=\"{{ 'after-sun-chest-sheet-mask-stylized.jpg' | file_img_url: '300x' }}\">\n    </div>\n\n    <div class=\"text--medium text--center col-xs-12 col-md-4\" style=\"padding:30px;\">\n        LIMITED TIME OFFER<br>\n        Free <a href=\"/products/after-sun-cool-glow-chest-area-sheet-mask\" style=\"text-decoration:underline;\">After Sun Cool & Glow Chest Area Sheet Mask</a> with all Suncare purchases.\n        <br> \n        <div class=\"button-wrapper\" style=\"padding-top:10px;\">\n           <a href=\"\" onclick=\"addItemToCart({{product.first_available_variant.id  | json }});return false;\" class=\"button button--primary\">ADD TO BAG</a>\n        </div>\n    </div>\n</div>\n{% endif %}",
        "background_type": "full_width",
        "background": "rgba(0,0,0,0)",
        "text_color": "rgba(0,0,0,0)"
      }
