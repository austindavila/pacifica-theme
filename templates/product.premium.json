    "263f0aa6-e3b5-405e-a925-e62d88e45ff3": {
      "type": "custom-html",
      "disabled": true,
      "settings": {
        "subheading": "",
        "title": "",
        "html": "<div class=\"row center-xs middle-xs\" style=\"margin-bottom:40px;\">\n<div class=\"col-xs-12 col-sm-4\"><img src=\"https://cdn.shopify.com/s/files/1/1515/0462/files/VC-BodySpray-EveryBodyCampaign-Updated.jpg?v=1666899819\" width=\"300\" loading=\"lazy\" alt=\"We Support the Every Body Campaign\"></div>\n<div class=\"col-xs-12 col-sm-8 text--left\" style=\"background-color: #397e58; padding:40px 20px; color:white;\">\n<span class=\"heading h2 color-white\"><i>The Every Body Campaign is the largest beauty industry-backed reproductive rights initiative to date.</i></span><br>\nWe’ve banded together with over 35+ beauty brands to protect Every Body’s right to choose – because reproductive rights are human rights. In partnership with all brands, Pacifica has made a donation to support reproductive justice and Reproductive Justice Collective SisterSong. \n<br><br>The SisterSong Women of Color Reproductive Justice Collective is the largest multi-ethnic collective of its kind in the nation. Since 1997, they have been activating individuals and organizations to improve institutional policies and systems that impact the reproductive lives of marginalized communities. Learn more at <a href=\"http://www.everybodycampaign.com\" target=\"_blank\" style=\"text-decoration:underline;\">everybodycampaign.com</a> \n\n</div>\n</div>",
        "no_padding_margin": false,
        "background_type": "full_width",
        "background": "rgba(0,0,0,0)",
        "text_color": "rgba(0,0,0,0)"
      }
    },
