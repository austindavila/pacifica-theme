      ],
      "settings": {
        "subheading": "",
        "title": "",
        "html": "<div class=\"row center-xs\">\n\n<div class=\" col-xs-10 col-md-10 text--center\" style=\"padding-bottom:15px;\"> <span class=\"heading heading--large font-california-coast\">your brain <br class=\"hidden-lap-and-up\">on our scent</span>\n</div>\n\n\n<div class=\"col-xs-10\" style=\"padding-bottom:25px;\">\n<p class=\"h5\">Aromapower™: Science meets nature with clinically studied <br class=\"hidden-phone\">ingredients that can elicit a positive effect</p>\n</div>\n\n\n<div class=\"col-xs-10 col-md-4 col-lg-3\">\n<img src=\"https://cdn.shopify.com/s/files/1/1515/0462/files/Aromapower-nose.png?v=1709830262\" alt=\"your nose\">\n<span class=\"h1\">your nose</span>\n<p class=\"h5\">inhales fragrance molecules that go straight to your brain's olfactory center</p>\n</div>\n\n<div class=\"col-xs-10 col-md-4 col-lg-3\">\n<img src=\"https://cdn.shopify.com/s/files/1/1515/0462/files/Aromapower-head.png?v=1709830262\" alt=\"your brain\">\n<span class=\"h1\">your brain</span>\n<p class=\"h5\">unconscious interpreter that pulls together memories, emotions, and motivations</p>\n</div>\n\n\n<div class=\"col-xs-10 col-md-4 col-lg-3\">\n<img src=\"https://cdn.shopify.com/s/files/1/1515/0462/files/Aromapower-heart.png?v=1709830262\" alt=\"your heart\">\n<span class=\"h1\">your feelings</span>\n<p class=\"h5\">past, present, and future come alive in your brain with memories and feelings activated by scent</p>\n</div>\n\n\n</div>",
        "no_padding_margin": true,
        "background_type": "full_width",
        "background": "#edf8ff",
        "text_color": "rgba(0,0,0,0)"
      }
    },
