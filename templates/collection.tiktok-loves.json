      ],
      "settings": {
        "subheading": "",
        "title": "",
        "html": "<div class=\"row center-xs\">\n\n<div class=\" col-xs-10 col-md-10 text--center\" style=\"padding-bottom:5px;\"> <span class=\"header h2 font-melt\">before &amp; after</span>\n</div>\n\n<div class=\"col-xs-10 col-md-10\" style=\"padding-bottom:25px;\">\n<p class=\"h5\">Vitamin C's anti-inflammatory properties also help to soothe and calm the skin, <br class=\"hidden-phone\">making it an essential ingredient for maintaining a healthy, radiant complexion. </p>\n</div>\n\n\n<div class=\"col-xs-10 col-md-4\">\n<img src=\"https://cdn.shopify.com/s/files/1/1515/0462/files/PAC_GLOW_BABY_BRIGHTENING_FACIAL_MASK_BEFORE_AFTER.jpg?v=1683928333\" alt=\"before &amp; after\">\n</div>\n\n<div class=\"col-xs-10 col-md-4\">\n<img src=\"https://cdn.shopify.com/s/files/1/1515/0462/files/PAC_GLOW_BABY_HYDRODEW_MOISTURE_GEL_BEFORE_AFTER.jpg?v=1684345963\" alt=\"before &amp; after\">\n</div>\n\n<div class=\"col-xs-10 col-md-4\">\n<img src=\"https://cdn.shopify.com/s/files/1/1515/0462/files/MODEL_BEFORE_AFTER_SKINCARE_2.jpg?v=1688653971\" alt=\"before &amp; after\">\n</div>\n\n\n</div>",
        "no_padding_margin": true,
        "background_type": "full_width",
        "background": "#edf8ff",
        "text_color": "rgba(0,0,0,0)"
      }
    },
