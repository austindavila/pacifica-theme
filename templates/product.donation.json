            "liquid": "{{ product.metafields.sf_product_tabs[\"tab_3_content\"] }}\n<span style=\"font-style:italic;\">We occasionally update formulas to make sure we are as clean and effective as possible. Please refer to the ingredient list on the product package you receive for the most up to date list of ingredients.</span>"
